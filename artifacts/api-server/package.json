    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "pino-pretty": "^13",
    "tsx": "catalog:"
  }
}
