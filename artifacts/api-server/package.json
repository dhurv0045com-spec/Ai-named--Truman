{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && tsx src/index.ts",
    "build": "tsc -b tsconfig.json",
    "start": "node --enable-source-maps ./dist/index.js",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
