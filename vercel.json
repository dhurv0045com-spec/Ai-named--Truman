{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd anra-workspace/frontend && npm install",
  "buildCommand": "cd anra-workspace/frontend && npm run build",
  "outputDirectory": "anra-workspace/frontend/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}